{
  "name": "fca-unofficial",
  "version": "1.4.1",
  "main": "src/index.js",
  "description": "A Facebook chat API that doesn't rely on XMPP. Will NOT be deprecated after April 30th 2015.",
  "scripts": {
    "test": "jest --runInBand --testPathIgnorePatterns=\"/test/integration/\"",
    "test:unit": "jest --runInBand",
    "test:integration": "jest --runInBand --testPathPattern=\"test/integration\"",
    "discover:e2ee-jid": "node scripts/discover-e2ee-jid.js",
    "listen:echo-all": "node scripts/listen-echo-all.js",
    "smoke:e2ee-send": "node scripts/e2ee-send-smoke.js",
    "debug:e2ee-send": "node scripts/e2ee-send-debug.js",
    "lint": "eslint \"src/**/*.js\" && eslint --env jest \"test/**/*.js\"",
    "prettier": "prettier \"src/**/*.js\" \"test/**/*.js\" --write"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VangBanLaNhat/fca-unofficial"
  },
  "keywords": [
    "facebook",
    "chat",
    "api",
    "fca"
  ],
  "bugs": {
    "url": "https://github.com/VangBanLaNhat/fca-unofficial/issues"
  },
  "author": "Avery, David, Maude, Benjamin, UIRI, HerokeyVN",
  "license": "MIT",
  "dependencies": {
    "bluebird": "^2.11.0",
    "cheerio": "^0.22.0",
    "https-proxy-agent": "^4.0.0",
    "meta-messenger.js": "^1.1.3",
    "mqtt": "^3.0.0",
    "npmlog": "^1.2.1",
    "request": "^2.88.2",
    "websocket-stream": "^5.5.2"
  },
  "pnpm": {
    "overrides": {
      "request@2.88.2>form-data": "2.5.5"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "eslint": "^7.32.0",
    "jest": "^27.5.1",
    "prettier": "^1.19.1"
  },
  "eslintConfig": {
    "env": {
      "es6": true,
      "es2017": true,
      "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "sourceType": "module"
    },
    "rules": {
      "linebreak-style": [
        "error",
        "unix"
      ],
      "semi": [
        "error",
        "always"
      ],
      "no-unused-vars": [
        1,
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "no-empty": [
        "error",
        {
          "allowEmptyCatch": true
        }
      ]
    }
  }
}
